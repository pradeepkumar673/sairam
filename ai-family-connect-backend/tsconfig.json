{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "outDir": "./dist",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "paths": {
      "@config/*":      ["src/config/*"],
      "@models/*":      ["src/models/*"],
      "@routes/*":      ["src/routes/*"],
      "@controllers/*": ["src/controllers/*"],
      "@middleware/*":  ["src/middleware/*"],
      "@utils/*":       ["src/utils/*"],
      "@validators/*":  ["src/validators/*"],
      "@sockets/*":     ["src/sockets/*"],
      "@jobs/*":        ["src/jobs/*"]
    }
  },
  "include": ["src/**/*", "server.ts"],
  "exclude": ["node_modules", "dist", "uploads"]
}