# ── Server ───────────────────────────────────────────────────
NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:5173

# ── MongoDB ──────────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017/ai_family_connect
MONGO_URI_PROD=mongodb+srv://pradeep:kumar@cluster0.h8cjl9e.mongodb.net/ai_family_connect

# ── JWT ──────────────────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_here_min_32_chars
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your_refresh_secret_here
JWT_REFRESH_EXPIRES_IN=30d

# ── Google Gemini AI ─────────────────────────────────────────
GEMINI_API_KEY=your_google_gemini_api_key_here

# ── Bcrypt ───────────────────────────────────────────────────
BCRYPT_SALT_ROUNDS=12

# ── File Uploads ─────────────────────────────────────────────
MAX_FILE_SIZE_MB=10
UPLOAD_PATH=uploads

# ── Rate Limiting (optional) ─────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=200

# ── Socket.io ────────────────────────────────────────────────
SOCKET_CORS_ORIGIN=http://localhost:5173

# ── Cron Jobs ────────────────────────────────────────────────
MEDICINE_REMINDER_CRON=* * * * *
MISSED_DOSE_CHECK_CRON=*/15 * * * *
REFILL_REMINDER_CRON=0 9 * * *

# ── Logging ──────────────────────────────────────────────────
LOG_LEVEL=debug
LOG_FILE=logs/app.log

# ── Invite Code ──────────────────────────────────────────────
INVITE_CODE_SECRET=family_invite_secret_here
INVITE_CODE_EXPIRY_HOURS=48

# ── Weather (mock) ───────────────────────────────────────────
MOCK_WEATHER_LOCATION=Chennai
